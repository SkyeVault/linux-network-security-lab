# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── WAN A ─────────────────────────────────────────────────────────────────────
WAN_A_IPV4=
WAN_A_IPV4_GATEWAY=
WAN_A_IPV6_PREFIX=          # e.g. 2001:db8:aaaa::/64
WAN_A_IPV6_GATEWAY=         # link-local or global gateway address
WAN_A_ROLE=                 # e.g. red-team | dmz | general

# ── WAN B ─────────────────────────────────────────────────────────────────────
WAN_B_IPV4=
WAN_B_IPV4_GATEWAY=
WAN_B_IPV6_PREFIX=          # e.g. 2001:db8:bbbb::/64
WAN_B_IPV6_GATEWAY=
WAN_B_ROLE=                 # e.g. blue-team | monitoring | general

# ── Proxmox ───────────────────────────────────────────────────────────────────
PROXMOX_HOST=               # management IP or hostname
PROXMOX_USER=root@pam
PROXMOX_NODE=               # node name shown in PVE UI

# ── Internal VLAN ranges ──────────────────────────────────────────────────────
# These are internal-only and safe to customize; kept here for consistency.
MGMT_VLAN=10
MGMT_SUBNET=10.10.10.0/24
WAN_A_VLAN_RANGE=100-199    # VLANs routed out WAN A
WAN_B_VLAN_RANGE=200-299    # VLANs routed out WAN B
SHARED_VLAN_RANGE=300-399   # Cross-WAN shared services (monitoring, mgmt)
